# Copy this file to `.env` and fill in your Atlas connection string.
# Keep your real credentials out of version control.

# Example MongoDB Atlas connection string (replace placeholders):
# MONGODB_URI="mongodb+srv://<DB_USER>:<DB_PASS>@cluster0.mongodb.net/relieflink?retryWrites=true&w=majority"

# If you prefer a direct connection (not recommended for production):
# MONGODB_URI="mongodb://username:password@host:port/relieflink"

# Optional: set NODE_ENV=production in production deployments
# NODE_ENV=development

# Optional server port override
# PORT=5001
